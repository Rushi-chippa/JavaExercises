import java.util.*;

class Fibonacci_series{
	public static void main(String[] args){
		int n,a=0,b=1,add;
			Scanner sc= new Scanner(System.in);
			System.out.println("Enter the n");
	
			n=sc.nextInt();
			int i=1;
			while(i<=n)
			{
			   System.out.println(a+" ");
			  add=a+b;
			  a=b;
			  b=add;
			}
	}
}